# LLM provider keys (set the one for your chosen model)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default model (examples: gpt-4.1-mini, claude-sonnet-4-20250514, gemini-2.5-flash)
MODEL=gpt-4.1-mini

# Demo Postgres from docker-compose.yml:
ASK_POSTGRES_PG_PORT=5001
DATABASE_URL=postgres://askpostgres:askpostgres@localhost:5001/analytics?sslmode=disable
